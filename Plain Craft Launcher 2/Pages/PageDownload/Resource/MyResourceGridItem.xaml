<Grid x:Class="MyResourceGridItem"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      xmlns:local="clr-namespace:PCL"
      Height="280"
      Width="220"
      Margin="5"
      SnapsToDevicePixels="True">
    <Border x:Name="PanBack"
            Background="{StaticResource ColorBrushBg1}"
            CornerRadius="12"
            BorderBrush="{StaticResource ColorBrush6}"
            BorderThickness="1">
        <Grid>
            <Grid.RowDefinitions>
                <RowDefinition Height="160"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="*"/>
            </Grid.RowDefinitions>
            
            <!-- Logo 区域 -->
            <Border Grid.Row="0" 
                    CornerRadius="8,8,0,0" 
                    Background="{StaticResource ColorBrush7}"
                    Margin="1">
                <Grid>
                    <local:MyImage x:Name="PathLogo" 
                                   Stretch="UniformToFill"
                                   FallbackSource="pack://application:,,,/images/Icons/NoIcon.png" />
                    <!-- 下载量和来源标签 -->
                    <Border CornerRadius="8,8,0,0" 
                            Background="#88000000" 
                            VerticalAlignment="Bottom" 
                            Height="60"
                            Margin="0">
                        <StackPanel Orientation="Horizontal" 
                                    VerticalAlignment="Bottom" 
                                    HorizontalAlignment="Right"
                                    Margin="8">
                            <Border Background="#55FFFFFF" 
                                    CornerRadius="4" 
                                    Padding="6,3" 
                                    Margin="0,0,4,0">
                                <StackPanel Orientation="Horizontal">
                                    <Path Fill="#333333" Stretch="Uniform" Height="12" Width="12" 
                                          Data="M955 610h-59c-15 0-29 13-29 29v196c0 15-13 29-29 29h-649c-15 0-29-13-29-29v-196c0-15-13-29-29-29h-59c-15 0-29 13-29 29V905c0 43 35 78 78 78h787c43 0 78-35 78-78V640c0-15-13-29-29-29zM492 740c11 11 29 11 41 0l265-265c11-11 11-29 0-41l-41-41c-11-11-29-11-41 0l-110 110c-11 11-33 3-33-13V68C571 53 555 39 541 39h-59c-15 0-29 13-29 29v417c0 17-21 25-33 13l-110-110c-11-11-29-11-41 0L226 433c-11 11-11 29 0 41L492 740z"
                                          Margin="0,0,4,0"/>
                                    <TextBlock x:Name="LabDownload" 
                                               Foreground="#333333" 
                                               FontSize="11"/>
                                </StackPanel>
                            </Border>
                            <Border Background="#55FFFFFF" 
                                    CornerRadius="4" 
                                    Padding="6,3">
                                <TextBlock x:Name="LabSource" 
                                           Foreground="#333333" 
                                           FontSize="11"/>
                            </Border>
                        </StackPanel>
                    </Border>
                </Grid>
            </Border>
            
            <!-- 标题 -->
            <StackPanel Grid.Row="1" Margin="12,10,12,0">
                <TextBlock x:Name="LabTitle" 
                           TextWrapping="NoWrap" 
                           TextTrimming="CharacterEllipsis" 
                           FontSize="15" 
                           FontWeight="SemiBold"
                           Foreground="{DynamicResource ColorBrush1}" />
                <TextBlock x:Name="LabTitleRaw" 
                           TextWrapping="NoWrap" 
                           TextTrimming="CharacterEllipsis" 
                           FontSize="12" 
                           Foreground="{StaticResource ColorBrushGray1}" 
                           Opacity="0.4" 
                           Margin="0,2,0,0"
                           Visibility="Collapsed"/>
            </StackPanel>
            
            <!-- 描述 -->
            <TextBlock x:Name="LabInfo" 
                       Grid.Row="2" 
                       Margin="12,6,12,0" 
                       TextWrapping="Wrap" 
                       TextTrimming="CharacterEllipsis" 
                       MaxHeight="48" 
                       FontSize="12" 
                       Foreground="{StaticResource ColorBrushGray3}" />
            
            <!-- 底部标签和时间 -->
            <StackPanel Grid.Row="3" 
                        Orientation="Horizontal" 
                        Margin="12,10,12,10" 
                        VerticalAlignment="Bottom">
                <Path Fill="{StaticResource ColorBrushGray4}" Stretch="Uniform" Height="14" Width="14"
                      Data="M810 403l-39 39c-10 10-28 10-39 0l-162-162v412c0 15-12 28-28 28h-56c-15 0-28-12-28-28v-412l-162 162c-10 10-28 10-39 0l-39-39c-10-10-10-28 0-39l278-278c10-10 28-10 39 0l278 278c10 10 10 28-0 39zM568 946h-112v-112h112v112z"
                      Margin="0,0,4,0"/>
                <TextBlock x:Name="LabTime" 
                           Margin="0,0,8,0" 
                           FontSize="11" 
                           Foreground="{StaticResource ColorBrushGray4}" 
                           VerticalAlignment="Center"/>
                
                <Border Background="{StaticResource ColorBrush7}" 
                        CornerRadius="4" 
                        Padding="6,2" 
                        Margin="0,0,4,0"
                        Visibility="Collapsed"
                        x:Name="TagBorder1">
                    <TextBlock x:Name="Tag1" FontSize="10" Foreground="{StaticResource ColorBrushGray3}"/>
                </Border>
                <Border Background="{StaticResource ColorBrush7}" 
                        CornerRadius="4" 
                        Padding="6,2" 
                        Margin="0,0,4,0"
                        Visibility="Collapsed"
                        x:Name="TagBorder2">
                    <TextBlock x:Name="Tag2" FontSize="10" Foreground="{StaticResource ColorBrushGray3}"/>
                </Border>
            </StackPanel>
            
            <!-- 收藏按钮 -->
            <StackPanel x:Name="PanButtons" 
                        Orientation="Horizontal" 
                        HorizontalAlignment="Right" 
                        VerticalAlignment="Top"
                        Margin="0,8,8,0" 
                        Opacity="0">
                <local:MyIconButton x:Name="BtnFavorite" 
                                    Height="28" 
                                    Width="28" 
                                    Background="#55000000"/>
            </StackPanel>
        </Grid>
    </Border>
</Grid>